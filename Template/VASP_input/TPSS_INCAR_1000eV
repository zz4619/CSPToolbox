System=Dummy_System

# Performance Optimization
NCORE= 8     #  2 4 8;  Rec: closest integer to sqrt(no of cores) that evenly divides the no of cores
KPAR= 4      #  ; Rec: integer that evenly divides the no of cores
LREAL= Auto  # True potentially changes energy results; Real space or reciprocal space calculation

# Electronic Optimization	
PREC= Accurate
ENCUT= 1000.0      #  change to 1000;  Basis set energy cut-off in eV
ALGO= FAST         # Algorithm for electronic optmization 
EDIFF= 0.000001  # could be 1e-8;  Termination criteria for SCF calculations (dE between steps in eV)

# Smearing Settings
#SIGMA= 0.05      # Width of smearing (eV) (Ignore for tetra)
ISMEAR= -5        # change between 0, -5; Type (0 = Gauss, -1 = Fermi, -2 = fixed INCAR, -3 = looped INCAR, -4 = tetra, -5 = Blochl corr. tetra)

# Ionic Relaxation
NSW= 250          # Number of steps allowed for relaxation (0 = single-point/no nuclei movement)
EDIFFG= -0.01     # Can be 1e-3, 1e-4;  Termination criteria for relaxation (neg: forces <|X| eV/A, pos: dE < X eV, zero =based on NSW steps)
ISIF= 3           # Change wiki;  DOF settings (3 = positions + cell shape + cell vol)
IBRION= 2         # change according to convergence; -1 = single-point calculation, 0 = MD calculation, 1-8 = relaxation

# XC functional and vdW correction
GGA= PE           # PBE GGA functional
metaGGA= TPSS     # TPSS meta-GGA
IVDW= 12          # Type of vdW correction (12 = DFT-D3 + BJ damping, 13 = DFT-D4, 20 = TS, 21 = TS + Hirshfeld partitioning)
VDW_S6= 1.0000    # Scale factor for C6 in D3
VDW_S8= 1.9435    # Scale factor for C8 in D3
VDW_A1= 0.4535    # Damping coefficient in BJ damping
VDW_A2= 4.4752    # Damping coefficient in BJ damping

# Output Settings
LCHARG= .TRUE.   # Write charge densities in CHGCAR and CHG
LWAVE= .TRUE.    # Write wavefunctions to WAVECAR

# energy change > 1-5 meV per atom should be noticed.